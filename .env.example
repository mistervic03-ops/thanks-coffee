SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
DATABASE_URL=postgresql://user:password@localhost:5432/recognition
DB_POOL_MIN=1
DB_POOL_MAX=5
DAILY_LIMIT=5
FEED_ENABLED=true
# Required when FEED_ENABLED=true. Optional when FEED_ENABLED=false. 전사 공지 채널 ID.
ANNOUNCEMENT_CHANNEL_ID=C...
# Optional extra admins. Slack workspace Admin/Owner users are included automatically.
ADMIN_USER_IDS=U123,U456
# Spark PoC default: keep scheduler off and run summaries manually.
# Set true to enable automatic weekly/monthly summary posts and 10-minute feed retry.
SCHEDULER_ENABLED=false
# Set true to enable /health and /ready. Spark should use 8020 to avoid existing services.
HEALTH_CHECK_ENABLED=false
HEALTH_CHECK_PORT=8000
LOG_LEVEL=INFO
RECOGNITION_EMOJI=☕
RECOGNITION_UNIT=커피
