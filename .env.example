SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
DATABASE_URL=postgresql://user:password@localhost:5432/recognition
DAILY_LIMIT=5
FEED_ENABLED=true
# Required when FEED_ENABLED=true. Optional when FEED_ENABLED=false.
FEED_CHANNEL_ID=C...
ADMIN_USER_IDS=U123,U456
# Spark PoC default: keep scheduler off unless one owner explicitly accepts duplicate summary risk.
# Set true to enable automatic weekly/monthly summary posts.
SCHEDULER_ENABLED=false
# Set true to enable /health and /ready. Spark should use 8020 to avoid existing services.
HEALTH_CHECK_ENABLED=false
HEALTH_CHECK_PORT=8000
LOG_LEVEL=INFO
RECOGNITION_EMOJI=☕
RECOGNITION_UNIT=커피
